<!-- STICKY RESERVE -->
<a href="#reserve" class="sticky-reserve" id="stickyBtn">Reserve a Table</a>

<script>
  // Nav scroll
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    navbar.classList.toggle('scrolled', window.scrollY > 60);
    document.getElementById('stickyBtn').style.opacity = window.scrollY > 300 ? '1' : '0';
    document.getElementById('stickyBtn').style.pointerEvents = window.scrollY > 300 ? 'auto' : 'none';
  });
  document.getElementById('stickyBtn').style.opacity = '0';

  // Mobile menu
  function toggleMenu() {
    document.getElementById('navLinks').classList.toggle('open');
  }

  // Menu tabs
  function switchTab(name) {
    document.querySelectorAll('.menu-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.menu-panel').forEach(p => p.classList.remove('active'));
    event.target.classList.add('active');
    document.getElementById('tab-' + name).classList.add('active');
  }

  // Reveal on scroll
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if(e.isIntersecting) { e.target.classList.add('visible'); } });
  }, { threshold: 0.15 });
  reveals.forEach(r => observer.observe(r));

  // Reserve handler
  function handleReserve() {
    const date = document.getElementById('r-date').value;
    const time = document.getElementById('r-time').value;
    const guests = document.getElementById('r-guests').value;
    if (!date) { alert('Please select a date.'); return; }
    alert(`Redirecting to OpenTable for ${guests} on ${new Date(date + 'T12:00').toLocaleDateString('en-US', {weekday:'long', month:'long', day:'numeric'})} at ${time}.\n\n(In production, this integrates with OpenTable or Tock API.)`);
  }

  // Set min date for reservation
  const dateInput = document.getElementById('r-date');
  dateInput.min = new Date().toISOString().split('T')[0];
</script>

</body>
</html>
